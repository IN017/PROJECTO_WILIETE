
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

// Define o enum para os perfis de usuário
enum Perfil {
  ADMIN
  PROFESSOR
  ENCARREGADO
}


model Usuario {
  id       Int     @id @default(autoincrement())
  nome     String
  email    String  @unique
  senha    String
  telefone String @unique
  perfil   Perfil
  imagem   String
  criadoEm DateTime @default(now())
  dataactualizacao DateTime @updatedAt
  @@map("usuarios")
}

model Aluno {
  id       Int     @id @default(autoincrement())
  nome     String
  numero_matricula String  @unique
  turmaId  Int
  encarregadoId Int
  telefone String @unique
  imagem   String
  criadoEm DateTime @default(now())
  dataactualizacao DateTime @updatedAt
  @@map("alunos")
}

model Turma {
  id       Int     @id @default(autoincrement())
  nome     String
  usuarioId Int
  criadoEm DateTime @default(now())
  dataactualizacao DateTime @updatedAt
  @@map("turmas")
}

model Aviso {
  id       Int     @id @default(autoincrement())
  titulo   String
  conteudo String
  imagem   String
  criadoEm DateTime @default(now())
  dataactualizacao DateTime @updatedAt
  @@map("avisos")
}

model Relatorio {
  id       Int     @id @default(autoincrement())
  titulo   String
  conteudo String
  criadoEm DateTime @default(now())
  dataactualizacao DateTime @updatedAt
  @@map("relatorios")
}



model Reuniao {
  id       Int     @id @default(autoincrement())
  linkMeeting String
  local String
  titulo   String
  criadoEm DateTime @default(now())
  dataactualizacao DateTime @updatedAt
  @@map("reunioes")
}

model Mensagem {
  id       Int     @id @default(autoincrement())
  remetenteId Int
  destinatarioId Int
  conteudo String
  criadoEm DateTime @default(now())
  dataactualizacao DateTime @updatedAt
  @@map("mensagens")
}

model Evento {
  id       Int     @id @default(autoincrement())
  titulo   String
  descricao String
  imagem   String
  criadoEm DateTime @default(now())
  dataactualizacao DateTime @updatedAt
  @@map("eventos")
}

model Nota {
  id       Int     @id @default(autoincrement())
  numero_matricula String
  disciplinaId Int
  valor    Float
  criadoEm DateTime @default(now())
  dataactualizacao DateTime @updatedAt
  @@map("notas")
}

model Disciplina {
  id       Int     @id @default(autoincrement())
  nome     String
  professorId Int
  descricao String
  criadoEm DateTime @default(now())
  dataactualizacao DateTime @updatedAt
  @@map("disciplinas")
}